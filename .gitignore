## .NET gitignore

# Build outputs
[Oo]bj/
[Bb]in/
out/
publish/

# NuGet
*.nupkg
*.snupkg
.nuget/
packages/
!**/packages/repositories.config
*.lock.json
!packages.lock.json
project.lock.json

# Visual Studio / Rider
.vs/
.idea/
*.user
*.suo
*.userosscache
*.sln.docstates
.vscode/

# OS
.DS_Store
Thumbs.db

# Test results
TestResults/
*.trx
coverage/
*.coveragexml

# Publish profiles
PublishProfiles/

# Secrets & Environment
.env
.env.*
!.env.example
appsettings.*.json
!appsettings.json
!appsettings.Development.json.example

# User secrets (local machine)
secrets.json

# Logs
*.log
logs/

# GeoIP database (büyük binary — repo'ya dahil edilmez)
*.mmdb
