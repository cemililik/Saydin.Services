{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "System.Net.Http": "Warning",
        "Polly": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "Otlp": {
    "Endpoint": "http://localhost:4317"
  },
  "ConnectionStrings": {
    "Postgres": ""
  },
  "ExternalApis": {
    "CoinGecko":  { "ApiKey": "" },
    "GoldApi":    { "ApiKey": "" },
    "TwelveData": { "ApiKey": "" },
    "Evds":       { "ApiKey": "" }
  },
  "IngestionWorkers": {
    "Tcmb":              { "Enabled": true,  "DailyRunUtcHour": 13, "DailyRunUtcMinute": 30 },
    "CoinGecko":         { "Enabled": true,  "DailyRunUtcHour": 2,  "DailyRunUtcMinute": 0  },
    "OpenExchangeRates": { "Enabled": true,  "DailyRunUtcHour": 22, "DailyRunUtcMinute": 0  },
    "TwelveData":        { "Enabled": true,  "DailyRunUtcHour": 15, "DailyRunUtcMinute": 0  },
    "EvdsInflation":     { "Enabled": true,  "MonthlyRunDay": 3,    "DailyRunUtcHour": 10,  "DailyRunUtcMinute": 0 }
  }
}
