# ============================================================
# Saydın — Ortam Değişkenleri Örneği
# Bu dosyayı kopyalayarak .env oluştur: cp .env.example .env
# .env asla git'e commit edilmez!
# ============================================================

# --- PostgreSQL ---
POSTGRES_DB=saydin
POSTGRES_USER=saydin
POSTGRES_PASSWORD=change_me_in_production

# --- Redis ---
REDIS_PASSWORD=

# --- Saydin.Api bağlantı dizeleri ---
SAYDIN_API_POSTGRES_CONNECTION=Host=localhost;Port=5432;Database=saydin;Username=saydin;Password=change_me
SAYDIN_API_REDIS_CONNECTION=localhost:6379

# --- Saydin.PriceIngestion bağlantı dizeleri ---
SAYDIN_INGESTION_POSTGRES_CONNECTION=Host=localhost;Port=5432;Database=saydin;Username=saydin;Password=change_me

# --- Dış API Key'leri (PriceIngestion) ---
# TCMB için API key gerekmez
COINGECKO_API_KEY=
GOLDAPI_API_KEY=
TWELVEDATA_API_KEY=

# --- OpenTelemetry ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
